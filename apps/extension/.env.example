# Build-time environment variables for the extension (Vite `import.meta.env`).
# Copy to .env.local and fill in as features that need them land.
# VITE_EXAMPLE_KEY=

# Web3Forms access key for the inline Request-a-retailer / Report-an-issue forms
# (wired in PR 9). Until set, they run in DEMO mode (simulated success).
# VITE_WEB3FORMS_KEY=
