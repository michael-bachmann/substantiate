{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  // Stories import @storybook/react-vite, which lives in the consuming apps, not
  // this package. They're typechecked by each app's Storybook build; here we
  // typecheck only the shared runtime source (so env.d.ts / svg.d.ts take effect).
  "exclude": ["**/*.stories.tsx"]
}
